{
  "_comment": "复制到项目根目录 .codebuddy/settings.local.json 或全局 ~/.codebuddy/settings.json",
  "_note": "请将 $CODEBUDDY_PROJECT_DIR 替换为实际路径，或把 hooks/traffic-light.sh 复制到项目 .codebuddy/hooks/ 下",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CODEBUDDY_PROJECT_DIR\"/traffic-light/hooks/traffic-light.sh idle"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CODEBUDDY_PROJECT_DIR\"/traffic-light/hooks/traffic-light.sh running"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CODEBUDDY_PROJECT_DIR\"/traffic-light/hooks/traffic-light.sh success"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CODEBUDDY_PROJECT_DIR\"/traffic-light/hooks/traffic-light.sh end"
          }
        ]
      }
    ]
  }
}

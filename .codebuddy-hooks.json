{
  "_comment": "复制到项目根目录 .codebuddy/settings.local.json 或全局 ~/.codebuddy/settings.json",
  "_note": "请将 TRAFFIC_LIGHT_DIR 替换为 traffic-light 目录的实际路径，或把 hooks/traffic-light.sh 复制到项目 .codebuddy/hooks/ 下",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LC_ALL=C.UTF-8 bash --noprofile --norc TRAFFIC_LIGHT_DIR/bind.sh --project <YOUR_PROJECT> && LC_ALL=C.UTF-8 bash --noprofile --norc TRAFFIC_LIGHT_DIR/hooks/traffic-light.sh idle"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LC_ALL=C.UTF-8 bash --noprofile --norc TRAFFIC_LIGHT_DIR/hooks/traffic-light.sh thinking"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "LC_ALL=C.UTF-8 bash --noprofile --norc TRAFFIC_LIGHT_DIR/hooks/traffic-light.sh running"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "LC_ALL=C.UTF-8 bash --noprofile --norc TRAFFIC_LIGHT_DIR/hooks/traffic-light.sh waiting"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LC_ALL=C.UTF-8 bash --noprofile --norc TRAFFIC_LIGHT_DIR/hooks/traffic-light.sh success"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LC_ALL=C.UTF-8 bash --noprofile --norc TRAFFIC_LIGHT_DIR/auto-stop.sh"
          }
        ]
      }
    ]
  }
}
